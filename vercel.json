{
  "buildCommand": "bash scripts/vercel_build.sh",
  "outputDirectory": ".vercel/output/static",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/app/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
